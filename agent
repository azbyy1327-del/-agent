st.set_page_config(page_title="营销数据分析 Agent", layout="wide")

# =========================
# 工具函数
# =========================
def safe_divide(a, b):
    return np.where((b == 0) | (pd.isna(b)), 0, a / b)

def format_number(x):
    try:
        return f"{x:,.2f}"
    except:
        return x

# =========================
# Agent 主类
# =========================
class MarketingDataAgent:
    def __init__(self):
        self.df = None
        self.standard_columns = {
            "date": ["date", "日期", "day", "投放日期", "时间"],
            "channel": ["channel", "渠道", "source", "media", "平台"],
            "campaign": ["campaign", "计划", "campaign_name", "广告计划", "活动"],
            "impressions": ["impressions", "曝光", "曝光量", "展示", "展示量"],
            "clicks": ["clicks", "点击", "点击量"],
            "cost": ["cost", "花费", "消耗", "spend", "广告花费"],
            "conversions": ["conversions", "转化", "转化数", "订单数", "leads"],
            "revenue": ["revenue", "收入", "成交金额", "gmv", "销售额"]
        }

    def load_data(self, file) -> pd.DataFrame:
        try:
            df = pd.read_csv(file)
        except:
            df = pd.read_excel(file)

        df = self._standardize_columns(df)
        df = self._clean_data(df)
        df = self._calculate_metrics(df)

        self.df = df
        return df

    def _standardize_columns(self, df: pd.DataFrame) -> pd.DataFrame:
        columns_lower = {col: str(col).strip().lower() for col in df.columns}
        reverse_map = {}

        for std_col, aliases in self.standard_columns.items():
            for original_col, lower_col in columns_lower.items():
                if lower_col in [a.lower() for a in aliases]:
                    reverse_map[original_col] = std_col
                    break

        df = df.rename(columns=reverse_map)
        return df

    def _clean_data(self, df: pd.DataFrame) -> pd.DataFrame:
        # 日期处理
        if "date" in df.columns:
            df["date"] = pd.to_datetime(df["date"], errors="coerce")

        # 数值字段处理
        numeric_cols = ["impressions", "clicks", "cost", "conversions", "revenue"]
        for col in numeric_cols:
            if col in df.columns:
                df[col] = pd.to_numeric(df[col], errors="coerce").fillna(0)

        # 文本字段处理
        text_cols = ["channel", "campaign"]
        for col in text_cols:
            if col in df.columns:
                df[col] = df[col].fillna("未知").astype(str)

        # 去重
        df = df.drop_duplicates()

        return df

    def _calculate_metrics(self, df: pd.DataFrame) -> pd.DataFrame:
        if "impressions" in df.columns and "clicks" in df.columns:
            df["CTR"] = safe_divide(df["clicks"], df["impressions"]) * 100
        else:
            df["CTR"] = 0

        if "cost" in df.columns and "clicks" in df.columns:
            df["CPC"] = safe_divide(df["cost"], df["clicks"])
        else:
            df["CPC"] = 0

        if "conversions" in df.columns and "clicks" in df.columns:
            df["CVR"] = safe_divide(df["conversions"], df["clicks"]) * 100
        else:
            df["CVR"] = 0

        if "cost" in df.columns and "conversions" in df.columns:
            df["CPA"] = safe_divide(df["cost"], df["conversions"])
        else:
            df["CPA"] = 0

        if "revenue" in df.columns and "cost" in df.columns:
            df["ROAS"] = safe_divide(df["revenue"], df["cost"])
        else:
            df["ROAS"] = 0

        return df

    def get_overview_metrics(self, df: pd.DataFrame) -> Dict:
        metrics = {}

        metrics["总曝光"] = df["impressions"].sum() if "impressions" in df.columns else 0
        metrics["总点击"] = df["clicks"].sum() if "clicks" in df.columns else 0
        metrics["总花费"] = df["cost"].sum() if "cost" in df.columns else 0
        metrics["总转化"] = df["conversions"].sum() if "conversions" in df.columns else 0
        metrics["总收入"] = df["revenue"].sum() if "revenue" in df.columns else 0

        metrics["CTR"] = (
            metrics["总点击"] / metrics["总曝光"] * 100
            if metrics["总曝光"] > 0 else 0
        )
        metrics["CPC"] = (
            metrics["总花费"] / metrics["总点击"]
            if metrics["总点击"] > 0 else 0
        )
        metrics["CVR"] = (
            metrics["总转化"] / metrics["总点击"] * 100
            if metrics["总点击"] > 0 else 0
        )
        metrics["CPA"] = (
            metrics["总花费"] / metrics["总转化"]
            if metrics["总转化"] > 0 else 0
        )
        metrics["ROAS"] = (
            metrics["总收入"] / metrics["总花费"]
            if metrics["总花费"] > 0 else 0
        )

        return metrics

    def analyze_by_channel(self, df: pd.DataFrame) -> pd.DataFrame:
        if "channel" not in df.columns:
            return pd.DataFrame()

        grouped = df.groupby("channel", as_index=False).agg({
            "impressions": "sum" if "impressions" in df.columns else "count",
            "clicks": "sum" if "clicks" in df.columns else "count",
            "cost": "sum" if "cost" in df.columns else "count",
            "conversions": "sum" if "conversions" in df.columns else "count",
            "revenue": "sum" if "revenue" in df.columns else "count"
        })

        grouped["CTR"] = safe_divide(grouped["clicks"], grouped["impressions"]) * 100
        grouped["CPC"] = safe_divide(grouped["cost"], grouped["clicks"])
        grouped["CVR"] = safe_divide(grouped["conversions"], grouped["clicks"]) * 100
        grouped["CPA"] = safe_divide(grouped["cost"], grouped["conversions"])
        grouped["ROAS"] = safe_divide(grouped["revenue"], grouped["cost"])

        return grouped.sort_values("cost", ascending=False)

    def analyze_by_campaign(self, df: pd.DataFrame) -> pd.DataFrame:
        if "campaign" not in df.columns:
            return pd.DataFrame()

        grouped = df.groupby("campaign", as_index=False).agg({
            "impressions": "sum" if "impressions" in df.columns else "count",
            "clicks": "sum" if "clicks" in df.columns else "count",
            "cost": "sum" if "cost" in df.columns else "count",
            "conversions": "sum" if "conversions" in df.columns else "count",
            "revenue": "sum" if "revenue" in df.columns else "count"
        })

        grouped["CTR"] = safe_divide(grouped["clicks"], grouped["impressions"]) * 100
        grouped["CPC"] = safe_divide(grouped["cost"], grouped["clicks"])
        grouped["CVR"] = safe_divide(grouped["conversions"], grouped["clicks"]) * 100
        grouped["CPA"] = safe_divide(grouped["cost"], grouped["conversions"])
        grouped["ROAS"] = safe_divide(grouped["revenue"], grouped["cost"])

        return grouped.sort_values("cost", ascending=False)

    def analyze_trend(self, df: pd.DataFrame) -> pd.DataFrame:
        if "date" not in df.columns:
            return pd.DataFrame()

        grouped = df.groupby("date", as_index=False).agg({
            "impressions": "sum" if "impressions" in df.columns else "count",
            "clicks": "sum" if "clicks" in df.columns else "count",
            "cost": "sum" if "cost" in df.columns else "count",
            "conversions": "sum" if "conversions" in df.columns else "count",
            "revenue": "sum" if "revenue" in df.columns else "count"
        })

        grouped["CTR"] = safe_divide(grouped["clicks"], grouped["impressions"]) * 100
        grouped["CPC"] = safe_divide(grouped["cost"], grouped["clicks"])
        grouped["CVR"] = safe_divide(grouped["conversions"], grouped["clicks"]) * 100
        grouped["CPA"] = safe_divide(grouped["cost"], grouped["conversions"])
        grouped["ROAS"] = safe_divide(grouped["revenue"], grouped["cost"])

        return grouped.sort_values("date")

    def identify_low_efficiency(self, df: pd.DataFrame) -> pd.DataFrame:
        result = self.analyze_by_campaign(df)
        if result.empty:
            return result

        # 规则：花费高于中位数 且 ROAS 低于中位数
        cost_median = result["cost"].median() if "cost" in result.columns else 0
        roas_median = result["ROAS"].median() if "ROAS" in result.columns else 0

        low_eff = result[
            (result["cost"] >= cost_median) &
            (result["ROAS"] <= roas_median)
        ].copy()

        return low_eff.sort_values(["ROAS", "cost"], ascending=[True, False])

    def answer_question(self, question: str, df: pd.DataFrame) -> str:
        q = question.lower()

        overview = self.get_overview_metrics(df)

        if any(k in q for k in ["整体", "总览", "概览", "summary", "overview"]):
            return (
                f"整体表现：总花费 {overview['总花费']:.2f}，"
                f"总收入 {overview['总收入']:.2f}，"
                f"ROAS {overview['ROAS']:.2f}，"
                f"CTR {overview['CTR']:.2f}%，"
                f"CVR {overview['CVR']:.2f}%。"
            )

        if any(k in q for k in ["渠道", "channel"]):
            channel_df = self.analyze_by_channel(df)
            if channel_df.empty:
                return "数据中没有 channel/渠道 字段。"
            top = channel_df.iloc[0]
            return (
                f"花费最高的渠道是 {top['channel']}，"
                f"花费 {top['cost']:.2f}，ROAS {top['ROAS']:.2f}，"
                f"CTR {top['CTR']:.2f}%，CVR {top['CVR']:.2f}%。"
            )

        if any(k in q for k in ["campaign", "计划", "活动"]):
            camp_df = self.analyze_by_campaign(df)
            if camp_df.empty:
                return "数据中没有 campaign/计划 字段。"
            top = camp_df.sort_values("ROAS", ascending=False).iloc[0]
            return (
                f"ROAS 最好的 Campaign 是 {top['campaign']}，"
                f"花费 {top['cost']:.2f}，收入 {top['revenue']:.2f}，ROAS {top['ROAS']:.2f}。"
            )

        if any(k in q for k in ["趋势", "trend", "最近", "按天"]):
            trend_df = self.analyze_trend(df)
            if trend_df.empty:
                return "数据中没有 date/日期 字段。"
            latest = trend_df.iloc[-1]
            return (
                f"最近一天表现：日期 {latest['date'].date()}，"
                f"花费 {latest['cost']:.2f}，收入 {latest['revenue']:.2f}，ROAS {latest['ROAS']:.2f}。"
            )

        if any(k in q for k in ["低效", "浪费", "优化"]):
            low_df = self.identify_low_efficiency(df)
            if low_df.empty:
                return "未识别到明显低效投放项，或缺少 campaign 字段。"
            top = low_df.iloc[0]
            return (
                f"建议优先优化 Campaign：{top['campaign']}，"
                f"花费 {top['cost']:.2f}，ROAS {top['ROAS']:.2f}，CPA {top['CPA']:.2f}。"
            )

        return "我支持的问题包括：整体概览、渠道分析、Campaign 分析、趋势分析、低效投放识别。"

