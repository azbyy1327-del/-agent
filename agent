        with col_f3:
            if "campaign" in filtered_df.columns:
                campaigns = ["全部"] + sorted(filtered_df["campaign"].dropna().unique().tolist())
                selected_campaign = st.selectbox("选择 Campaign", campaigns)
                if selected_campaign != "全部":
                    filtered_df = filtered_df[filtered_df["campaign"] == selected_campaign]

